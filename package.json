{
  "name": "@coti/pod-sdk",
  "version": "0.1.0",
  "description": "Coti PoD SDK - Solidity contracts and TypeScript utilities for PoD dApps",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts/*": "./contracts/*"
  },
  "files": [
    "dist",
    "contracts"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test:integ": "vitest run tests/integ",
    "docs:install": "make -C docs install",
    "docs:serve": "make -C docs serve",
    "docs:build": "make -C docs build"
  },
  "keywords": [
    "coti",
    "pod",
    "sdk",
    "solidity",
    "mpc"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@coti-io/coti-sdk-typescript": "^1.0.0",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cotitech-io/coti-pod-sdk.git"
  },
  "homepage": "https://github.com/cotitech-io/coti-pod-sdk#readme",
  "bugs": {
    "url": "https://github.com/cotitech-io/coti-pod-sdk/issues"
  }
}
